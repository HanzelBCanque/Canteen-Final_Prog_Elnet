@page
@model DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>QuickServe - Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f0f4f8;
            min-height: 100vh;
        }

        /* ── Sidebar ── */
        .sidebar {
            width: 200px;
            min-height: 100vh;
            background-color: #dce8f5;
            position: fixed;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
            padding: 0;
            z-index: 100;
        }

        .sidebar-logo {
            padding: 18px 20px 24px 20px;
            border-bottom: 1px solid #c5d8ec;
        }

        .sidebar-logo span {
            font-size: 1.35rem;
            font-weight: 900;
            letter-spacing: -0.5px;
            color: #1a1a2e;
        }

        .sidebar-logo span em {
            font-style: normal;
            color: #1a1a2e;
        }

        .sidebar-logo .logo-hat {
            display: inline-block;
            margin-left: 2px;
            font-size: 1.1rem;
        }

        .sidebar-nav {
            flex: 1;
            padding: 20px 14px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .nav-item-link {
            display: block;
            padding: 14px 20px;
            border-radius: 30px;
            font-weight: 700;
            font-size: 1rem;
            color: #2d3a4a;
            text-decoration: none;
            transition: background 0.15s, color 0.15s;
            background: transparent;
        }

        .nav-item-link:hover {
            background: #c2d8ef;
            color: #1a1a2e;
        }

        .nav-item-link.active {
            background: #ffffff;
            color: #1a1a2e;
            box-shadow: 0 2px 8px rgba(0,0,0,0.07);
        }

        .sidebar-logout {
            padding: 18px 20px;
            border-top: 1px solid #c5d8ec;
        }

        .sidebar-logout a {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 700;
            font-size: 0.95rem;
            color: #2d3a4a;
            text-decoration: none;
        }

        .sidebar-logout a:hover {
            color: #1a1a2e;
        }

        /* ── Topbar ── */
        .topbar {
            position: fixed;
            top: 0;
            left: 200px;
            right: 0;
            height: 62px;
            background-color: #f0f4f8;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 0 32px;
            z-index: 99;
            border-bottom: 1px solid #dce8f5;
        }

        .topbar-user {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1rem;
            color: #2d3a4a;
            font-weight: 500;
        }

        .topbar-user .admin-name {
            color: #e05c2a;
            font-weight: 700;
        }

        .topbar-avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: #b0c8e0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            color: #2d3a4a;
        }

        /* ── Main Content ── */
        .main-content {
            margin-left: 200px;
            margin-top: 62px;
            padding: 28px 32px;
            min-height: calc(100vh - 62px);
        }

        /* ── Hero Banner ── */
        .dashboard-hero {
            background: linear-gradient(135deg, #7cb9f0 0%, #a8d1f5 60%, #b8dbf7 100%);
            border-radius: 18px;
            padding: 32px 36px;
            margin-bottom: 28px;
        }

        .dashboard-hero h1 {
            font-size: 2rem;
            font-weight: 900;
            font-style: italic;
            color: #1a1a2e;
            margin-bottom: 4px;
        }

        .dashboard-hero p {
            font-size: 0.95rem;
            font-style: italic;
            color: #2d3a4a;
            font-weight: 500;
        }

        /* ── Stat Cards ── */
        .stat-card {
            background: #ffffff;
            border-radius: 14px;
            padding: 22px 26px;
            box-shadow: 0 1px 6px rgba(0,0,0,0.05);
        }

        .stat-card .stat-label {
            font-size: 0.8rem;
            color: #6b7a8d;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            margin-bottom: 8px;
        }

        .stat-card .stat-value {
            font-size: 2.2rem;
            font-weight: 800;
            color: #1a1a2e;
            line-height: 1;
        }

        .badge-up {
            font-size: 0.78rem;
            font-weight: 700;
            color: #1a9e5a;
            background: #e0f7ec;
            border-radius: 20px;
            padding: 2px 8px;
            margin-left: 8px;
        }

        /* ── Sales Report Table ── */
        .report-card {
            background: #ffffff;
            border-radius: 14px;
            padding: 24px 26px;
            box-shadow: 0 1px 6px rgba(0,0,0,0.05);
        }

        .report-card .report-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 18px;
        }

        .report-card .report-title {
            font-size: 1rem;
            font-weight: 700;
            color: #1a1a2e;
        }

        .report-card .download-link {
            font-size: 0.82rem;
            color: #4a8fcb;
            text-decoration: none;
            font-weight: 600;
        }

        .report-card .download-link:hover {
            text-decoration: underline;
        }

        .report-table {
            width: 100%;
            border-collapse: collapse;
        }

        .report-table th {
            font-size: 0.72rem;
            font-weight: 700;
            color: #8a9bb0;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            padding: 6px 0 10px 0;
            border-bottom: 1px solid #eef2f7;
        }

        .report-table td {
            padding: 12px 0;
            font-size: 0.9rem;
            color: #2d3a4a;
            border-bottom: 1px solid #f0f4f8;
        }

        .report-table tbody tr:last-child td {
            border-bottom: none;
        }

        .report-table td.text-end,
        .report-table th.text-end {
            text-align: right;
        }

        /* ── Right Panel ── */
        .right-panel {
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .panel-card {
            background: #ffffff;
            border-radius: 14px;
            padding: 20px 22px;
            box-shadow: 0 1px 6px rgba(0,0,0,0.05);
        }

        .panel-section-title {
            font-size: 0.72rem;
            font-weight: 800;
            color: #8a9bb0;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 16px;
        }

        /* Menu Alerts */
        .alert-item {
            padding: 12px 0;
            border-bottom: 1px solid #f0f4f8;
        }

        .alert-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .alert-item-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 6px;
        }

        .alert-item-name {
            font-size: 0.9rem;
            font-weight: 700;
            color: #1a1a2e;
        }

        .badge-low-stock {
            font-size: 0.7rem;
            font-weight: 700;
            color: #e05c2a;
            background: #fde8e0;
            border-radius: 6px;
            padding: 2px 8px;
        }

        .badge-moderate {
            font-size: 0.7rem;
            font-weight: 700;
            color: #c48a00;
            background: #fff3cd;
            border-radius: 6px;
            padding: 2px 8px;
        }

        .alert-item-stock {
            font-size: 0.78rem;
            color: #8a9bb0;
        }

        .stock-controls {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .stock-btn {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            border: 1.5px solid #d0dbe8;
            background: #f5f8fc;
            color: #2d3a4a;
            font-size: 1rem;
            line-height: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-weight: 700;
            transition: background 0.1s;
        }

        .stock-btn:hover {
            background: #dce8f5;
        }

        .alert-item-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        /* Active Orders */
        .order-divider {
            border: none;
            border-top: 1px solid #f0f4f8;
            margin: 16px 0 16px 0;
        }

        .order-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #f0f4f8;
        }

        .order-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .order-id {
            font-size: 0.72rem;
            color: #8a9bb0;
            font-weight: 600;
        }

        .order-name {
            font-size: 0.9rem;
            font-weight: 700;
            color: #1a1a2e;
        }

        .btn-complete {
            font-size: 0.72rem;
            font-weight: 700;
            color: #2d3a4a;
            border: 1.5px solid #b0c8e0;
            border-radius: 8px;
            background: #ffffff;
            padding: 5px 14px;
            cursor: pointer;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            transition: background 0.12s, border-color 0.12s;
            white-space: nowrap;
        }

        .btn-complete:hover {
            background: #dce8f5;
            border-color: #7cb9f0;
        }
    </style>
</head>
<body>

    <!-- ── Sidebar ── -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <span><em>QU!CK</em><em>SERVE</em> <span class="logo-hat">🏠</span></span>
        </div>
        <nav class="sidebar-nav">
            <a href="/Dashboard" class="nav-item-link active">Dashboard</a>
            <a href="/Menu" class="nav-item-link">Menu</a>
            <a href="/Orders" class="nav-item-link">Orders</a>
            <a href="/Report" class="nav-item-link">Report</a>
        </nav>
        <div class="sidebar-logout">
            <a href="/Logout">
                <i class="bi bi-box-arrow-right" style="font-size:1.1rem;"></i>
                Log Out
            </a>
        </div>
    </aside>

    <!-- ── Topbar ── -->
    <header class="topbar">
        <div class="topbar-user">
            <div class="topbar-avatar">
                <i class="bi bi-person-circle"></i>
            </div>
            <span>Welcome, <span class="admin-name">Admin</span>!</span>
        </div>
    </header>

    <!-- ── Main Content ── -->
    <main class="main-content">

        <!-- Hero Banner -->
        <div class="dashboard-hero">
            <h1>Dashboard Overview</h1>
            <p>Real-time status of your canteen operations.</p>
        </div>

        <!-- Stat Cards Row -->
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="stat-card">
                    <div class="stat-label">Total Orders Today</div>
                    <div class="stat-value">
                        142
                        <span class="badge-up">+12.5%</span>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="stat-card">
                    <div class="stat-label">Total Sales (PHP)</div>
                    <div class="stat-value">
                        ₱8,420.00
                        <span class="badge-up">+4.2%</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom Row: Sales Report + Right Panel -->
        <div class="row g-3">

            <!-- Sales Report Table -->
            <div class="col-lg-7">
                <div class="report-card h-100">
                    <div class="report-header">
                        <span class="report-title">Recent Sales Report</span>
                        <a href="#" class="download-link">Download CSV</a>
                    </div>
                    <table class="report-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th class="text-end">Total Orders</th>
                                <th class="text-end">Total Sales</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>May 12, 2026</td>
                                <td class="text-end">142</td>
                                <td class="text-end">₱8420.00</td>
                            </tr>
                            <tr>
                                <td>May 11, 2026</td>
                                <td class="text-end">128</td>
                                <td class="text-end">₱7680.50</td>
                            </tr>
                            <tr>
                                <td>May 10, 2026</td>
                                <td class="text-end">156</td>
                                <td class="text-end">₱9240.00</td>
                            </tr>
                            <tr>
                                <td>May 09, 2026</td>
                                <td class="text-end">112</td>
                                <td class="text-end">₱6430.00</td>
                            </tr>
                            <tr>
                                <td>May 08, 2026</td>
                                <td class="text-end">134</td>
                                <td class="text-end">₱7920.00</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Right Panel: Menu Alerts + Active Orders -->
            <div class="col-lg-5">
                <div class="panel-card h-100">

                    <!-- Menu Alerts -->
                    <div class="panel-section-title">Menu Alerts</div>

                    <div class="alert-item">
                        <div class="alert-item-header">
                            <span class="alert-item-name">Chicken Adobo Bowl</span>
                            <span class="badge-low-stock">Low Stock</span>
                        </div>
                        <div class="alert-item-footer">
                            <span class="alert-item-stock">Stock: 4 / 50</span>
                            <div class="stock-controls">
                                <button class="stock-btn">−</button>
                                <button class="stock-btn">+</button>
                            </div>
                        </div>
                    </div>

                    <div class="alert-item">
                        <div class="alert-item-header">
                            <span class="alert-item-name">Iced Tea (Large)</span>
                            <span class="badge-moderate">Moderate</span>
                        </div>
                        <div class="alert-item-footer">
                            <span class="alert-item-stock">Stock: 18 / 100</span>
                            <div class="stock-controls">
                                <button class="stock-btn">−</button>
                                <button class="stock-btn">+</button>
                            </div>
                        </div>
                    </div>

                    <hr class="order-divider" />

                    <!-- Active Orders -->
                    <div class="panel-section-title">Active Orders</div>

                    <div class="order-item">
                        <div>
                            <div class="order-id">#ORD-9021</div>
                            <div class="order-name">Pork Sisig Rice</div>
                        </div>
                        <button class="btn-complete">Complete</button>
                    </div>

                    <div class="order-item">
                        <div>
                            <div class="order-id">#ORD-9022</div>
                            <div class="order-name">Beef Pares Bowl</div>
                        </div>
                        <button class="btn-complete">Complete</button>
                    </div>

                    <div class="order-item">
                        <div>
                            <div class="order-id">#ORD-9023</div>
                            <div class="order-name">Chicken Adobo + Rice</div>
                        </div>
                        <button class="btn-complete">Complete</button>
                    </div>

                </div>
            </div>

        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
